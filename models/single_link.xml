<mujoco model="single_link">
  <!-- Assignment 1-5 starter model: one body, one joint, one motor, one sensor -->
  <compiler angle="degree"/>
  <option gravity="0 0 -9.81" timestep="0.002"/>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1"/>
    <geom type="plane" size="5 5 0.1" rgba="0.9 0.9 0.9 1"/>

    <body name="base" pos="0 0 0.5">
      <geom type="box" size="0.2 0.2 0.2" mass="2" rgba="0.5 0.5 0.5 1"/>
      <joint name="hinge1" type="hinge" axis="0 1 0"/>

      <body name="link1" pos="0 0 0.5">
        <geom type="capsule" fromto="0 0 -0.25 0 0 0.25" size="0.05" mass="1"
              rgba="0.2 0.6 1 1"/>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="hinge1" gear="50"/>
  </actuator>

  <sensor>
    <jointpos joint="hinge1"/>
    <touch name="link1_touch" site="link1_site"/>
  </sensor>

  <!-- Note: touch sensor needs a site — students add this in assignment 5 -->
</mujoco>
